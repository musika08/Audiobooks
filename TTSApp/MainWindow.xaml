<Window x:Class="TTSApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TTSApp"
        Title="AI Audiobook Studio"
        Height="980" Width="1450"
        MinHeight="720" MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushWindowBg}"
        FontFamily="Segoe UI"
        AllowDrop="True"
        Drop="Window_Drop">
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Undo}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Redo}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.UndoAllCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.RedoAllCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Find}"/>
        <KeyBinding Key="H" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Replace}"/>
        <KeyBinding Key="H" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.ReplaceAllCommand}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="CommandBinding_Open_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="CommandBinding_Save_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="CommandBinding_New_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Undo}" Executed="CommandBinding_Undo_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Redo}" Executed="CommandBinding_Redo_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Find}" Executed="CommandBinding_Find_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Replace}" Executed="CommandBinding_Replace_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.UndoAllCommand}" Executed="CommandBinding_UndoAll_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.RedoAllCommand}" Executed="CommandBinding_RedoAll_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.ReplaceAllCommand}" Executed="CommandBinding_ReplaceAll_Executed"/>
    </Window.CommandBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- MENU BAR -->
        <Menu Grid.Row="0" Background="{DynamicResource BrushMenuBg}" Foreground="{DynamicResource BrushTextPrimary}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Click="MenuNew_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Click="MenuOpen_Click" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Click="MenuSave_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Click="MenuSaveAs_Click"/>
                <Separator/>
                <MenuItem Header="_Import Document..." Click="MenuImport_Click"/>
                <MenuItem Header="_Export Audio..." Click="MenuExport_Click"/>
                <Separator/>
                <MenuItem Header="Recent Files" x:Name="MenuRecentFiles" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Save _Project..." Click="MenuSaveProject_Click"/>
                <MenuItem Header="Open Pro_ject..." Click="MenuOpenProject_Click"/>
                <Separator/>
                <MenuItem Header="Import from _URL..." Click="MenuImportUrl_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="MenuUndo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="Undo _All" Click="MenuUndoAll_Click" InputGestureText="Ctrl+Shift+Z"/>
                <MenuItem Header="_Redo" Click="MenuRedo_Click" InputGestureText="Ctrl+Y"/>
                <MenuItem Header="Redo A_ll" Click="MenuRedoAll_Click" InputGestureText="Ctrl+Shift+Y"/>
                <Separator/>
                <MenuItem Header="Cu_t" Click="MenuCut_Click" InputGestureText="Ctrl+X"/>
                <MenuItem Header="_Copy" Click="MenuCopy_Click" InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste" Click="MenuPaste_Click" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="_Find" Click="MenuFind_Click" InputGestureText="Ctrl+F"/>
                <MenuItem Header="_Replace..." Click="MenuReplace_Click" InputGestureText="Ctrl+H"/>
                <MenuItem Header="Replace A_ll..." Click="MenuReplaceAll_Click" InputGestureText="Ctrl+Shift+H"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Mini Player" Click="MenuMiniPlayer_Click"/>
                <Separator/>
                <MenuItem Header="_Theme">
                    <MenuItem Header="_Dark" x:Name="MenuThemeDark" IsCheckable="True" Checked="MenuTheme_Checked"/>
                    <MenuItem Header="_Light" x:Name="MenuThemeLight" IsCheckable="True" Checked="MenuTheme_Checked"/>
                    <MenuItem Header="_Midnight" x:Name="MenuThemeMidnight" IsCheckable="True" Checked="MenuTheme_Checked"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Dictionary" Click="MenuDictionary_Click"/>
            <MenuItem Header="_Settings" Click="MenuSettings_Click"/>
        </Menu>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="{DynamicResource BrushPanelBg}" Padding="14,10"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Col 0: Open button -->
                <Button Grid.Column="0" x:Name="BtnBrowse" Width="96" Height="34"
                        Background="{DynamicResource BrushAccentBlue}" Foreground="White" FontSize="13"
                        Click="BtnBrowse_Click">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,7,0">
                            <Path Style="{StaticResource LucideIcon}" Stroke="White" Data="{StaticResource GeoFolderOpen}"/>
                        </Viewbox>
                        <TextBlock Text="Open" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Col 1: File path -->
                <TextBlock Grid.Column="1" x:Name="TxtFilePath" Text="No file selected"
                           VerticalAlignment="Center" Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="12" Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis" MaxWidth="260"/>

                <!-- Col 2: Settings (center) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Model -->
                    <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                        <TextBlock Text="MODEL" Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CmbModel" Width="160" Height="32" FontSize="12"
                                  SelectionChanged="CmbModel_SelectionChanged">
                            <ComboBoxItem Tag="kokoro-multi-lang-v1_0">Kokoro Multi-Lang v1.0</ComboBoxItem>
                            <ComboBoxItem Tag="kokoro-multi-lang-v1_1">Kokoro Multi-Lang v1.1</ComboBoxItem>
                            <ComboBoxItem Tag="xtts-v2">XTTS v2 (GPU)</ComboBoxItem>
                            <ComboBoxItem Tag="chatterbox">Chatterbox (GPU)</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!-- Voice -->
                    <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                        <TextBlock Text="VOICE" Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal" Height="32">
                            <ComboBox x:Name="CmbVoice" Width="140" Height="32" FontSize="12" VerticalAlignment="Center"/>
                            <Button x:Name="BtnCloneVoice" Width="32" Height="32" Margin="4,0,0,0"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource BrushButtonBg}" Foreground="{DynamicResource BrushTextPrimary}"
                                    Click="BtnCloneVoice_Click" ToolTip="Clone voice from an audio file (GPU engines)">
                                <Viewbox Width="15" Height="15"><Path Style="{StaticResource LucideIcon}" Data="{StaticResource GeoMic}"/></Viewbox>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Speed -->
                    <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                        <TextBlock Text="SPEED" Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="32">
                            <Slider x:Name="SliderSpeed" Width="90" VerticalAlignment="Center"
                                    Minimum="0.5" Maximum="2.0" Value="1.0" TickFrequency="0.1"/>
                            <Border Background="{DynamicResource BrushPanelBgAlt}" CornerRadius="4"
                                    Padding="6,0" Margin="6,0,0,0" Width="42" Height="32">
                                <TextBlock x:Name="LblSpeed" Text="1.0x"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Format -->
                    <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                        <TextBlock Text="FORMAT" Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CmbFormat" Width="88" Height="32" FontSize="12" SelectedIndex="1">
                            <ComboBoxItem>WAV</ComboBoxItem>
                            <ComboBoxItem>MP3</ComboBoxItem>
                            <ComboBoxItem>M4B</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!-- Provider -->
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="PROVIDER" Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <ComboBox x:Name="CmbProvider" Width="110" Height="32" FontSize="12" SelectedIndex="0">
                            <ComboBoxItem>CPU</ComboBoxItem>
                            <ComboBoxItem>CUDA</ComboBoxItem>
                            <ComboBoxItem>DirectML</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <!-- Col 3: Merge toggle -->
                <StackPanel Grid.Column="3" Orientation="Vertical" Margin="12,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="MERGE" Foreground="{DynamicResource BrushTextMuted}"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="ChkMerge" VerticalAlignment="Center" HorizontalAlignment="Center"
                              Foreground="{DynamicResource BrushTextSecondary}" FontSize="12"/>
                </StackPanel>

                <!-- Col 4: Action buttons -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnPreview" Width="106" Height="34"
                            Background="{DynamicResource BrushAccentPurple}" Foreground="White" FontSize="13"
                            Click="BtnPreview_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,7,0">
                                <Path Style="{StaticResource LucideIcon}" Stroke="White" Fill="White" Data="{StaticResource GeoPlay}"/>
                            </Viewbox>
                            <TextBlock Text="Preview" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnConvert" Width="114" Height="34"
                            Background="{DynamicResource BrushAccentGreen}" Foreground="White" FontSize="13" FontWeight="Bold"
                            Click="BtnConvert_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="15" Height="15" Margin="0,0,7,0">
                                <Path Style="{StaticResource LucideIcon}" Stroke="White" Data="{StaticResource GeoZap}"/>
                            </Viewbox>
                            <TextBlock x:Name="LblConvert" Text="Convert" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Chapters -->
            <Border Grid.Column="0" Background="{DynamicResource BrushPanelBg}" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📚 Chapters" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,8"/>

                    <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,8">
                        <Button x:Name="BtnSelectAll" Height="26" Margin="0,0,4,0"
                                Background="{DynamicResource BrushButtonBg}" Click="BtnSelectAll_Click" ToolTip="Select all chapters">
                            <Viewbox Width="16" Height="16"><Path Stroke="#3FB950" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}" Data="{StaticResource GeoCheck}"/></Viewbox>
                        </Button>
                        <Button x:Name="BtnSelectNone" Height="26" Margin="0,0,4,0"
                                Background="{DynamicResource BrushButtonBg}" Click="BtnSelectNone_Click" ToolTip="Deselect all chapters">
                            <Viewbox Width="15" Height="15"><Path Stroke="#F85149" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}" Data="{StaticResource GeoX}"/></Viewbox>
                        </Button>
                        <Button x:Name="BtnAddChapter" Height="26" Margin="0,0,4,0"
                                Background="{DynamicResource BrushButtonBg}" Click="BtnAddChapter_Click" ToolTip="Add chapter">
                            <Viewbox Width="15" Height="15"><Path Style="{StaticResource LucideIcon}" Data="{StaticResource GeoPlus}"/></Viewbox>
                        </Button>
                        <Button x:Name="BtnMoveUp" Height="26" Margin="0,0,4,0"
                                Background="{DynamicResource BrushButtonBg}" Click="BtnMoveUp_Click" ToolTip="Move chapter up">
                            <Viewbox Width="13" Height="13"><Path Fill="{DynamicResource BrushTextPrimary}" Data="{StaticResource GeoTriUp}"/></Viewbox>
                        </Button>
                        <Button x:Name="BtnMoveDown" Height="26" Margin="0,0,4,0"
                                Background="{DynamicResource BrushButtonBg}" Click="BtnMoveDown_Click" ToolTip="Move chapter down">
                            <Viewbox Width="13" Height="13"><Path Fill="{DynamicResource BrushTextPrimary}" Data="{StaticResource GeoTriDown}"/></Viewbox>
                        </Button>
                        <Button x:Name="BtnDeleteChapter" Height="26"
                                Background="{DynamicResource BrushButtonBg}" Click="BtnDeleteChapter_Click" ToolTip="Delete chapter">
                            <Viewbox Width="15" Height="15"><Path Style="{StaticResource LucideIcon}" Data="{StaticResource GeoTrash}"/></Viewbox>
                        </Button>
                    </UniformGrid>

                    <TextBox x:Name="TxtChapterSearch" Grid.Row="2" Height="26" FontSize="12" Margin="0,0,0,8"
                             Background="{DynamicResource BrushPanelBgAlt}" Foreground="{DynamicResource BrushTextPrimary}"
                             BorderBrush="{DynamicResource BrushBorder}" Padding="6,2"
                             TextChanged="TxtChapterSearch_TextChanged"
                             ToolTip="Filter chapters by title"/>

                    <Border Grid.Row="3" Background="{DynamicResource BrushPanelBgAlt}" CornerRadius="10" Padding="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox x:Name="ChaptersList" Background="Transparent" BorderThickness="0"
                                     SelectionChanged="ChaptersList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="2,0,8,0"
                                                      Click="ChkChapter_IsCheckedChanged"/>
                                            <Border Background="{DynamicResource BrushAccentBlue}" CornerRadius="4"
                                                    MinWidth="22" Height="20" Padding="5,0" Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Number}" Foreground="White"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="12" MaxWidth="165" ToolTip="{Binding Title}"/>
                                            <TextBlock Text="{Binding StatusGlyph}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource BrushAccentGreen}"
                                                       FontSize="12" FontWeight="Bold" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                            Margin="2,1">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BrushListSelected}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BrushListHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="4" Background="{DynamicResource BrushPanelBgAlt}" CornerRadius="8"
                            Padding="6" Margin="0,8,0,0" HorizontalAlignment="Stretch">
                        <Grid>
                            <Image x:Name="ImgCover" Height="120" Stretch="Uniform"
                                   MouseLeftButtonDown="ImgCover_Click"/>
                            <TextBlock x:Name="TxtCoverHint" Text="📷 Click to add cover"
                                       Foreground="{DynamicResource BrushTextMuted}" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock Grid.Row="5" x:Name="TxtChapterCount" Text="0 chapters"
                               Foreground="{DynamicResource BrushTextMuted}" FontSize="11"
                               Margin="0,8,0,0" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Row="5" x:Name="TxtTotalDuration" Text=""
                               Foreground="{DynamicResource BrushTextMuted}" FontSize="11"
                               Margin="0,8,0,0" HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <!-- RIGHT: Content -->
            <Border Grid.Column="1" Background="{DynamicResource BrushPanelBg}" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="TxtChapterTitle" Text="📝 Chapter Content" FontSize="18"
                                   FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnPrevChapter" Width="38" Height="32" Margin="0,0,5,0"
                                    Background="{DynamicResource BrushButtonBg}"
                                    Click="BtnPrevChapter_Click" ToolTip="Previous chapter">
                                <Viewbox Width="18" Height="18"><Path Fill="{DynamicResource BrushTextPrimary}" Data="{StaticResource GeoTriLeft}"/></Viewbox>
                            </Button>
                            <Button x:Name="BtnNextChapter" Width="38" Height="32" Margin="0,0,10,0"
                                    Background="{DynamicResource BrushButtonBg}"
                                    Click="BtnNextChapter_Click" ToolTip="Next chapter (fetches next web page if imported from URL)">
                                <Viewbox Width="18" Height="18"><Path Fill="{DynamicResource BrushTextPrimary}" Data="{StaticResource GeoTriRight}"/></Viewbox>
                            </Button>
                            <Button x:Name="BtnTidy" Width="38" Height="32" Margin="0,0,5,0"
                                    Background="{DynamicResource BrushButtonBg}"
                                    Click="BtnTidy_Click" ToolTip="Tidy this chapter (fix spacing &amp; paragraphs)">
                                <Viewbox Width="20" Height="20"><Path Style="{StaticResource LucideIcon}" Data="{StaticResource GeoAlignLeft}"/></Viewbox>
                            </Button>
                            <Button x:Name="BtnTidyAll" Width="38" Height="32" Margin="0,0,12,0"
                                    Background="{DynamicResource BrushButtonBg}"
                                    Click="BtnTidyAll_Click" ToolTip="Tidy all checked chapters">
                                <Viewbox Width="20" Height="20"><Path Style="{StaticResource LucideIcon}" Data="{StaticResource GeoListChecks}"/></Viewbox>
                            </Button>
                            <TextBlock Text="Voice:" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextMuted}"
                                       FontSize="11" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbChapterVoice" Width="150" Height="26" FontSize="11"
                                      SelectionChanged="CmbChapterVoice_SelectionChanged"
                                      ToolTip="Override the voice for this chapter only"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock x:Name="TxtWordCount" Text="Select a chapter to preview"
                                   Foreground="{DynamicResource BrushTextMuted}" FontSize="11"/>
                        <TextBlock x:Name="TxtDuration" Text="" 
                                   Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="12,0,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{DynamicResource BrushPanelBgAlt}" CornerRadius="10" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="TxtPreview" IsReadOnly="False" TextWrapping="Wrap"
                                     FontFamily="Cambria" FontSize="14"
                                     TextAlignment="Justify"
                                     AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     TextChanged="TxtPreview_TextChanged"/>
                        </ScrollViewer>
                    </Border>

                    <!-- AUDIO PLAYER -->
                    <Border Grid.Row="3" Background="{DynamicResource BrushPanelBgAlt}" CornerRadius="10" Padding="10" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Canvas x:Name="WaveformCanvas" Grid.Row="0" Height="40" Margin="0,0,0,6"
                                    Background="Transparent"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Button x:Name="BtnRewind" Content="⏮" Width="50" Height="42" FontSize="18"
                                            Background="{DynamicResource BrushButtonBg}" Foreground="{DynamicResource BrushTextPrimary}"
                                            Click="BtnRewind_Click" ToolTip="Rewind"/>
                                    <Button x:Name="BtnPlayPause" Content="▶" Width="50" Height="42" FontSize="18" Margin="6,0"
                                            Background="{DynamicResource BrushButtonBg}" Foreground="{DynamicResource BrushTextPrimary}"
                                            Click="BtnPlayPause_Click" ToolTip="Play / Pause"/>
                                    <Button x:Name="BtnStop" Content="⏹" Width="50" Height="42" FontSize="18" Margin="0,0,6,0"
                                            Background="{DynamicResource BrushButtonBg}" Foreground="{DynamicResource BrushTextPrimary}"
                                            Click="BtnStop_Click" ToolTip="Stop"/>
                                    <Button x:Name="BtnForward" Content="⏭" Width="50" Height="42" FontSize="18"
                                            Background="{DynamicResource BrushButtonBg}" Foreground="{DynamicResource BrushTextPrimary}"
                                            Click="BtnForward_Click" ToolTip="Forward"/>
                                </StackPanel>
                                <Slider x:Name="SliderSeek" Grid.Column="1" VerticalAlignment="Center" Margin="10,0"
                                        Minimum="0" Maximum="100" Value="0" IsMoveToPointEnabled="True"
                                        Thumb.DragCompleted="SliderSeek_DragCompleted"/>
                                <TextBlock x:Name="LblTime" Grid.Column="2" Text="0:00 / 0:00" 
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           VerticalAlignment="Center" FontSize="11" Width="80" TextAlignment="Right"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="3" Background="{DynamicResource BrushPanelBg}" Padding="14,8"
                BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="TxtStatus" Text="Ready"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" x:Name="ProgressBar" Height="10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="LblProgress" Text="" Width="48" TextAlignment="Right"
                               Foreground="{DynamicResource BrushTextPrimary}" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
