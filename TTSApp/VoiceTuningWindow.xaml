<Window x:Class="TTSApp.VoiceTuningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Tuning" Height="440" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushWindowBg}"
        FontFamily="Segoe UI" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🎚 Voice Tuning" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource BrushTextPrimary}"/>
            <TextBlock x:Name="LblEngine" Text="" Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" Margin="0,4,0,0"/>
            <TextBlock Text="Applies to GPU engines (XTTS / Chatterbox / VibeVoice)."
                       Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <!-- Temperature -->
            <Grid x:Name="RowTemp" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Temperature" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                <Slider Grid.Column="1" x:Name="SldTemp" Minimum="0.1" Maximum="1.5" VerticalAlignment="Center" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" x:Name="LblTemp" TextAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
            </Grid>

            <!-- Repetition penalty (XTTS) -->
            <Grid x:Name="RowRep" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Repetition penalty" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                <Slider Grid.Column="1" x:Name="SldRep" Minimum="1.0" Maximum="10.0" VerticalAlignment="Center" TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" x:Name="LblRep" TextAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
            </Grid>

            <!-- Exaggeration (Chatterbox) -->
            <Grid x:Name="RowExag" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Exaggeration" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                <Slider Grid.Column="1" x:Name="SldExag" Minimum="0.25" Maximum="2.0" VerticalAlignment="Center" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" x:Name="LblExag" TextAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
            </Grid>

            <!-- CFG weight (Chatterbox) -->
            <Grid x:Name="RowCfgW" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CFG weight" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                <Slider Grid.Column="1" x:Name="SldCfgW" Minimum="0.0" Maximum="1.0" VerticalAlignment="Center" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" x:Name="LblCfgW" TextAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
            </Grid>

            <!-- CFG scale (VibeVoice) -->
            <Grid x:Name="RowCfgS" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Guidance (CFG)" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13"/>
                <Slider Grid.Column="1" x:Name="SldCfgS" Minimum="1.0" Maximum="3.0" VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" x:Name="LblCfgS" TextAlignment="Right" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
            </Grid>

            <TextBlock x:Name="LblHint" Text="" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Reset Defaults" Width="110" Height="32" Margin="0,0,10,0" Click="BtnReset_Click"/>
            <Button Content="Cancel" Width="80" Height="32" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Save" Width="80" Height="32" Background="{DynamicResource BrushAccentBlue}" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
