<Window x:Class="TTSApp.VoiceCastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Cast" Height="430" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushWindowBg}"
        FontFamily="Segoe UI" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🎭 Voice Cast" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource BrushTextPrimary}"/>
            <TextBlock Text="Narration and quoted dialogue use separately-chosen engines and voices."
                       Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <CheckBox Grid.Row="1" x:Name="ChkCastEnabled" Content="Enable Voice Cast"
                  Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,0,0,14"/>

        <!-- Narrator -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource BrushTextMuted}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Narrator (narration)" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Engine" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
                    <ComboBox Grid.Column="1" x:Name="CmbNarratorEngine" Height="28" SelectionChanged="CmbNarratorEngine_SelectionChanged"/>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Voice" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
                    <ComboBox Grid.Column="1" x:Name="CmbNarratorVoice" Height="28"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Dialogue -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BrushTextMuted}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Dialogue (quoted speech)" FontWeight="Bold" Foreground="{DynamicResource BrushTextPrimary}" FontSize="13" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Engine" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
                    <ComboBox Grid.Column="1" x:Name="CmbDialogueEngine" Height="28" SelectionChanged="CmbDialogueEngine_SelectionChanged"/>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Voice" VerticalAlignment="Center" Foreground="{DynamicResource BrushTextPrimary}" FontSize="12"/>
                    <ComboBox Grid.Column="1" x:Name="CmbDialogueVoice" Height="28"/>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" x:Name="LblHint" TextWrapping="Wrap" VerticalAlignment="Top"
                   Foreground="{DynamicResource BrushTextMuted}" FontSize="11"
                   Text="Allowed: Kokoro + Kokoro, Kokoro + one GPU engine, or the same GPU engine twice (different voices). Two different GPU engines is not allowed."/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="32" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Save" Width="80" Height="32" Background="{DynamicResource BrushAccentBlue}" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
