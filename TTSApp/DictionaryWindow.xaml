<Window x:Class="TTSApp.DictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pronunciation Dictionary" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushWindowBg}"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📖 Pronunciation Dictionary" FontSize="22" FontWeight="Bold" 
                   Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="1" Text="When the app encounters the word on the left, it will pronounce it as the word on the right."
                   Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <Border Grid.Row="2" Background="{DynamicResource BrushPanelBg}" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtOriginal" Grid.Column="0" Height="28" Margin="0,0,6,0"
                             Background="{DynamicResource BrushPanelBgAlt}" 
                             Foreground="{DynamicResource BrushTextPrimary}" 
                             BorderBrush="{DynamicResource BrushBorder}" Padding="6,2"
                             FontSize="12" ToolTip="Original word"/>
                    <TextBox x:Name="TxtReplacement" Grid.Column="1" Height="28" Margin="0,0,6,0"
                             Background="{DynamicResource BrushPanelBgAlt}" 
                             Foreground="{DynamicResource BrushTextPrimary}" 
                             BorderBrush="{DynamicResource BrushBorder}" Padding="6,2"
                             FontSize="12" ToolTip="Pronounce as"/>
                    <Button Grid.Column="2" Content="Add" Width="60" Height="28" Click="BtnAdd_Click"/>
                </Grid>
                <ListView Grid.Row="1" x:Name="ListDict" Margin="0,10,0,0" Background="Transparent"
                          Foreground="{DynamicResource BrushTextPrimary}" BorderThickness="0">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource BrushPanelBgAlt}"/>
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="4,3"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushListHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BrushListSelected}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Original" Width="200" DisplayMemberBinding="{Binding Key}"/>
                            <GridViewColumn Header="Pronounce As" Width="200" DisplayMemberBinding="{Binding Value}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Import…" Width="80" Height="32" Margin="0,0,8,0" Click="BtnImport_Click"/>
                <Button Content="Export…" Width="80" Height="32" Click="BtnExport_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Remove Selected" Width="110" Height="32" Margin="0,0,10,0" Click="BtnRemove_Click"/>
                <Button Content="Close" Width="80" Height="32" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
