<Window x:Class="TTSApp.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Player" Height="100" Width="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#FF2D2D2D" CornerRadius="12" BorderBrush="#FF444444" BorderThickness="1">
        <Grid Margin="12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TxtMiniTitle" Text="Chapter" FontSize="12" FontWeight="SemiBold"
                       Foreground="#FFFFFFFF" TextTrimming="CharacterEllipsis" MaxWidth="340" Margin="0,0,0,6"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="⏮" Width="32" Height="32" FontSize="14"
                            Background="#FF4A4A4A" Foreground="White" BorderThickness="0"
                            Click="BtnRewind_Click"/>
                    <Button x:Name="BtnMiniPlay" Content="⏸" Width="32" Height="32" FontSize="14" Margin="4,0"
                            Background="#FF4A4A4A" Foreground="White" BorderThickness="0"
                            Click="BtnPlayPause_Click"/>
                    <Button Content="⏹" Width="32" Height="32" FontSize="14" Margin="0,0,4,0"
                            Background="#FF4A4A4A" Foreground="White" BorderThickness="0"
                            Click="BtnStop_Click"/>
                    <Button Content="⏭" Width="32" Height="32" FontSize="14"
                            Background="#FF4A4A4A" Foreground="White" BorderThickness="0"
                            Click="BtnForward_Click"/>
                </StackPanel>
                <Slider x:Name="SliderMiniSeek" Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                        Minimum="0" Maximum="100" Value="0" IsMoveToPointEnabled="True"
                        Thumb.DragCompleted="SliderSeek_DragCompleted"/>
                <TextBlock x:Name="LblMiniTime" Grid.Column="2" Text="0:00 / 0:00"
                           Foreground="#FFAAAAAA" VerticalAlignment="Center" FontSize="10"
                           Width="70" TextAlignment="Right"/>
            </Grid>
        </Grid>
    </Border>
</Window>
